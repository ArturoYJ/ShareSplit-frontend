generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  firebaseUid String   @unique @map("firebase_uid") @db.VarChar(255)
  name        String   @db.VarChar(255)
  email       String   @unique @db.VarChar(255)
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  groupMembers GroupMember[]
  paidExpenses Expense[]     @relation("PaidExpenses")
  itemSplits   ItemSplit[]

  @@map("users")
}

model Group {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(255)
  inviteCode String   @unique @map("invite_code") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  members  GroupMember[]
  expenses Expense[]

  @@map("groups")
}

model GroupMember {
  groupId  String   @map("group_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("group_members")
}

model Expense {
  id           String   @id @default(uuid()) @db.Uuid
  groupId      String   @map("group_id") @db.Uuid
  paidByUserId String   @map("paid_by_user_id") @db.Uuid
  title        String   @db.VarChar(255)
  totalAmount  Decimal  @map("total_amount") @db.Decimal(12, 2)
  date         DateTime @default(now()) @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  group      Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidByUser User   @relation("PaidExpenses", fields: [paidByUserId], references: [id], onDelete: Restrict)
  items      Item[]

  @@map("expenses")
}

model Item {
  id        String  @id @default(uuid()) @db.Uuid
  expenseId String  @map("expense_id") @db.Uuid
  name      String  @db.VarChar(255)
  price     Decimal @db.Decimal(12, 2)

  expense Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  splits  ItemSplit[]

  @@map("items")
}

model ItemSplit {
  itemId      String  @map("item_id") @db.Uuid
  userId      String  @map("user_id") @db.Uuid
  splitAmount Decimal @map("split_amount") @db.Decimal(12, 2)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([itemId, userId])
  @@map("item_splits")
}
